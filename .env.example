# ============================================================
#  Agent Platform - 环境变量配置模板
#  使用方法：复制本文件为 .env.local 并填入实际值
#    cp .env.example .env.local
#
#  ⚠️  切勿将 .env.local 提交到版本控制！
# ============================================================

# ===== 运行环境 =====
# 可选值：local / dev / test / staging / prod
ENVIRONMENT=local

# ===== 数据库 =====
# PostgreSQL 密码（必填，开发环境可设为 dev_password）
DB_PASSWORD=dev_password
# 完整数据库连接串（可选，设置后覆盖 DB_PASSWORD）
# DATABASE_URL=postgresql+asyncpg://app_user:dev_password@localhost:5432/agent_platform

# ===== Redis =====
# Redis 密码（必填，开发环境可设为 dev_password）
REDIS_PASSWORD=dev_password
# 完整 Redis 连接串（可选，设置后覆盖 REDIS_PASSWORD）
# REDIS_URL=redis://:dev_password@localhost:6379/0

# ===== 认证密钥 =====
# JWT 签名密钥（必填，至少 32 字符，生产环境必须使用强密钥）
JWT_SECRET=dev-only-change-me-in-production-min-32-chars!!!
# gRPC 服务间认证密钥（必填，至少 32 字符）
GRPC_AUTH_SECRET=dev-secret-change-in-prod-min-32-chars!!!
# Java 服务间认证密钥（必填）
SERVICE_AUTH_SECRET=dev-secret-change-in-prod-min-32-chars!!!

# ===== LLM Provider API Keys =====
# 至少配置一个模型提供商的 API Key
QWEN_API_KEY=
DEEPSEEK_API_KEY=
GLM_API_KEY=
KIMI_API_KEY=
EMBEDDING_API_KEY=

# ===== 对象存储 =====
MINIO_ROOT_USER=minioadmin
# MinIO 密码（必填，开发环境可设为 minioadmin123）
MINIO_ROOT_PASSWORD=minioadmin123

# ===== 可选配置 =====
# OpenTelemetry
OTEL_ENABLED=false
# OTLP_ENDPOINT=http://localhost:4317

# 日志级别
LOG_LEVEL=INFO

# Kafka（审批回调，默认关闭）
# KAFKA_SERVERS=localhost:9092
# KAFKA_APPROVAL_TOPIC=agent-platform.approval

# 通知 Webhook（可选）
# WECOM_WEBHOOK=
# DINGTALK_WEBHOOK=
