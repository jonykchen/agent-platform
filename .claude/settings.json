{
  "$schema": "https://claude.ai/schema/settings.json",
  "project": {
    "name": "agent-platform",
    "description": "企业级 Agent 平台 - Python 编排 + Java 核心服务"
  },
  "context": {
    "projectFile": "CLAUDE.md",
    "memoryDir": ".claude/projects"
  },
  "permissions": {
    "allow": [
      "Bash(make:*)",
      "Bash(mvn:*)",
      "Bash(./mvnw:*)",
      "Bash(mvnw:*)",
      "Bash(uv:*)",
      "Bash(pip:*)",
      "Bash(pytest:*)",
      "Bash(ruff:*)",
      "Bash(mypy:*)",
      "Bash(buf:*)",
      "Bash(docker compose:*)",
      "Bash(docker-compose:*)",
      "Bash(docker:*)",
      "Bash(psql:*)",
      "Bash(redis-cli:*)",
      "Bash(kafka-*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git branch:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git stash:*)",
      "Bash(git restore:*)",
      "Bash(gh:*)",
      "Bash(curl:*)",
      "Bash(jq:*)",
      "Bash(ls:*)",
      "Bash(dir:*)",
      "Bash(find:*)",
      "Bash(where:*)",
      "Bash(which:*)",
      "Bash(grep:*)",
      "Bash(findstr:*)",
      "Bash(trivy:*)",
      "Bash(gitleaks:*)",
      "Bash(python:*)",
      "Bash(python3:*)",
      "Bash(node:*)",
      "Bash(npm:*)",
      "Read(**)",
      "Edit(**)",
      "Write(services/**)",
      "Write(shared/**)",
      "Write(tests/**)",
      "Write(docs/**)",
      "Write(.claude/**)",
      "Write(contracts/openapi/**)",
      "Write(scripts/**)"
    ],
    "deny": [
      "Read(.env*)",
      "Read(**/secrets/**)",
      "Read(**/credentials/**)",
      "Read(**/*.pem)",
      "Read(**/*.key)",
      "Read(**/*.pfx)",
      "Write(.env*)",
      "Write(**/secrets/**)",
      "Write(**/*.pem)",
      "Write(**/*.key)",
      "Write(**/*.pfx)",
      "Bash(rm -rf /*:*)",
      "Bash(rm -rf ~:*)",
      "Bash(rd /s /q:*)",
      "Bash(git push --force:*)",
      "Bash(git reset --hard origin:*)",
      "Bash(sudo:*)",
      "Bash(runas:*)",
      "Bash(chmod 777:*)",
      "Bash(icacls:*)",
      "Bash(format:*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": { "toolName": "Write", "pathGlob": "**/*.py" },
        "hooks": [
          {
            "type": "command",
            "command": "python -m py_compile \"${CLAUDE_FILE_PATH}\" 2>&1 || python3 -m py_compile \"${CLAUDE_FILE_PATH}\" 2>&1 || echo 'SYNTAX_ERROR'"
          }
        ]
      },
      {
        "matcher": { "toolName": "Write", "pathGlob": "**/*.sql" },
        "hooks": [
          {
            "type": "command",
            "command": "grep -E '(DROP|TRUNCATE|DELETE FROM audit)' \"${CLAUDE_FILE_PATH}\" 2>/dev/null && echo '⚠️ DANGEROUS_SQL' || findstr /R \"DROP TRUNCATE DELETE\" \"${CLAUDE_FILE_PATH}\" 2>nul && echo '⚠️ DANGEROUS_SQL' || echo 'SQL_OK'"
          }
        ]
      },
      {
        "matcher": { "toolName": "Write", "pathGlob": "**/*.java" },
        "hooks": [
          { "type": "command", "command": "echo 'Java file - ensure Spring Boot conventions'" }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": { "toolName": "Write", "pathGlob": "services/orchestrator-python/**/*.py" },
        "hooks": [
          {
            "type": "command",
            "command": "cd services/orchestrator-python && (uv run ruff check \"${CLAUDE_FILE_PATH}\" --fix 2>/dev/null || true) && (uv run ruff format \"${CLAUDE_FILE_PATH}\" 2>/dev/null || true) && echo '✅ Formatted'"
          }
        ]
      },
      {
        "matcher": { "toolName": "Write", "pathGlob": "services/model-gateway-python/**/*.py" },
        "hooks": [
          {
            "type": "command",
            "command": "cd services/model-gateway-python && (uv run ruff check \"${CLAUDE_FILE_PATH}\" --fix 2>/dev/null || true) && (uv run ruff format \"${CLAUDE_FILE_PATH}\" 2>/dev/null || true) && echo '✅ Formatted'"
          }
        ]
      },
      {
        "matcher": { "toolName": "Write", "pathGlob": "services/knowledge-python/**/*.py" },
        "hooks": [
          {
            "type": "command",
            "command": "cd services/knowledge-python && (uv run ruff check \"${CLAUDE_FILE_PATH}\" --fix 2>/dev/null || true) && (uv run ruff format \"${CLAUDE_FILE_PATH}\" 2>/dev/null || true) && echo '✅ Formatted'"
          }
        ]
      },
      {
        "matcher": { "toolName": "Edit", "pathGlob": "contracts/proto/**/*.proto" },
        "hooks": [
          {
            "type": "command",
            "command": "buf lint \"${CLAUDE_FILE_PATH}\" 2>/dev/null || echo '⚠️ Proto lint issues'"
          }
        ]
      },
      {
        "matcher": { "toolName": "Write", "pathGlob": "**/test_*.py" },
        "hooks": [
          { "type": "command", "command": "echo '🧪 Test file created - run: make test'" }
        ]
      },
      {
        "matcher": { "toolName": "Write", "pathGlob": "services/**/graph/nodes/*.py" },
        "hooks": [
          { "type": "command", "command": "echo '🤖 LangGraph node - update graph/builder.py'" }
        ]
      },
      {
        "matcher": { "toolName": "Write", "pathGlob": "services/**/tools/*.py" },
        "hooks": [
          { "type": "command", "command": "echo '🔧 Tool created - register in tools/__init__.py'" }
        ]
      }
    ]
  },
  "mcpServers": {},
  "env": {
    "PYTHON_VERSION": "3.12",
    "JAVA_VERSION": "21",
    "NODE_VERSION": "20"
  }
}
