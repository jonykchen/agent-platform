{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "LOG_LEVEL": "DEBUG",
    "ENVIRONMENT": "development"
  },
  "permissions": {
    "allow": [
      "Bash(cat:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(python -m json.tool:*)",
      "Bash(uv run:*)",
      "Bash(conda info:*)",
      "Bash(pnpm install:*)",
      "Bash(npx tsc:*)",
      "Bash(git checkout:*)",
      "Bash(gh pr view:*)",
      "Bash(gh pr list:*)",
      "Bash(mvn compile:*)",
      "Bash(mvn test:*)",
      "Bash(buf lint:*)",
      "mcp__langchain-docs__query_docs_filesystem_docs_by_lang_chain",
      "Bash(DB_PASSWORD=dev_password mvn spring-boot:run -Dspring-boot.run.arguments=\"--spring.profiles.active=local\")"
    ]
  },
  "extends": "./settings.json"
}
