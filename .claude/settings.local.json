{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "LOG_LEVEL": "DEBUG",
    "ENVIRONMENT": "development"
  },
  "permissions": {
    "allow": [
      "Bash(cat:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(python -m json.tool:*)",
      "Bash(uv run:*)",
      "Bash(conda info:*)",
      "Bash(pnpm install:*)",
      "Bash(npx tsc:*)",
      "Bash(git checkout:*)",
      "Bash(gh pr view:*)",
      "Bash(gh pr list:*)",
      "Bash(mvn compile:*)",
      "Bash(mvn test:*)",
      "Bash(buf lint:*)",
      "mcp__langchain-docs__query_docs_filesystem_docs_by_lang_chain",
      "Bash(DB_PASSWORD=dev_password mvn spring-boot:run -Dspring-boot.run.arguments=\"--spring.profiles.active=local\")",
      "Bash(netstat -ano)",
      "Bash(pkill -f \"spring-boot:run\")",
      "Bash(rm -rf node_modules/.vite)",
      "Bash(uvicorn app.main:app --port 8001 --reload)",
      "Bash(uvicorn app.main:app --port 8001)",
      "Bash(set GRPC_PORT=60051)",
      "Bash(scripts/unix/dev.sh setup *)",
      "Bash(command -v uv)",
      "Bash(command -v buf)",
      "Bash(awk -F/ '{print $1\"/\"$2}')",
      "Bash(echo \"exit: $?\")",
      "Bash(export CLAUDE_CODE_TMPDIR=/Users/jonychen/IdeaProjects/agent-platform/.tmp_claude)",
      "Bash(mkdir -p /Users/jonychen/IdeaProjects/agent-platform/.tmp_claude)",
      "Bash(cd /Users/jonychen/IdeaProjects/agent-platform)",
      "Bash(grep -rln \"agent_memory\" shared/sql/)",
      "Bash(echo \"=== files above ===\")",
      "Bash(echo \"=== knowledge_chunk 定义与向量索引 ===\")",
      "Bash(sed -n '/CREATE TABLE knowledge_chunk/,/^CREATE INDEX.*hnsw/p' shared/sql/V001__init_schema.sql)",
      "Bash(echo \"=== knowledge embedding 配置 ===\")",
      "Bash(echo \"\")",
      "Bash(echo \"=== knowledge 调用 embedding 的地方 ===\")",
      "Bash(cd /Users/jonychen/IdeaProjects/agent-platform/services/orchestrator-python)",
      "Bash(echo \"OK 语法通过\")",
      "Bash(cd /Users/jonychen/IdeaProjects/agent-platform/services/gateway-java)",
      "Bash(echo \"=== SecurityConfig 路径 ===\")",
      "Bash(echo \"=== Controllers ===\")",
      "Bash(mvn -o compile -q)",
      "Bash(echo \"EXIT=$?\")",
      "Bash(echo \"--- class 产物 ---\")",
      "Read(//tmp/**)",
      "Bash(cd /Users/jonychen/IdeaProjects/agent-platform/services/knowledge-python)",
      "Bash(echo \"=== retrievers ===\")",
      "Bash(echo \"=== hybrid_retriever.search 签名与 rerank 调用 ===\")",
      "Bash(/Users/jonychen/.local/bin/ruff check *)",
      "Bash(pip3 show *)",
      "Bash(export TMPDIR=/tmp/claude-tmp)",
      "Bash(mkdir -p /tmp/claude-tmp)",
      "Bash(echo \"Orchestrator not ready\")"
    ]
  },
  "extends": "./settings.json"
}
