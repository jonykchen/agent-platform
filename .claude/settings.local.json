{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "LOG_LEVEL": "DEBUG",
    "ENVIRONMENT": "development"
  },
  "permissions": {
    "allow": [
      "Bash(cat:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(python -m json.tool:*)",
      "Bash(uv run:*)",
      "Bash(conda info:*)",
      "Bash(pnpm install:*)",
      "Bash(npx tsc:*)",
      "Bash(git checkout:*)",
      "Bash(gh pr view:*)",
      "Bash(gh pr list:*)",
      "Bash(mvn compile:*)",
      "Bash(mvn test:*)",
      "Bash(buf lint:*)"
    ]
  },
  "extends": "./settings.json"
}
