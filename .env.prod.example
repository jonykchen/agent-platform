# ============================================================
#  Agent Platform - 生产环境配置模板
#  复制为 .env.prod 并填入真实值
#  ⚠️  绝对不要提交到 Git！
# ============================================================

# ====== 数据库配置 ======
POSTGRES_USER=app_user
POSTGRES_PASSWORD=<生成一个32位随机密码>
POSTGRES_DB=agent_platform

# ====== Redis 配置 ======
REDIS_PASSWORD=<生成一个32位随机密码>

# ====== MinIO 配置 ======
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=<生成一个32位随机密码>

# ====== JWT 配置 ======
JWT_SECRET=<生成一个64位随机字符串>

# ====== 加密配置 ======
ENCRYPTION_KEY=<生成一个32位Base64编码的密钥>

# ====== LLM 配置 ======
LLM_API_KEY=<你的LLM API密钥>
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_DEFAULT_MODEL=qwen-max

# ====== Grafana 配置 ======
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=<生成一个强密码>

# ====== 域名配置 ======
DOMAIN=your-domain.com
SSL_EMAIL=your-email@example.com
