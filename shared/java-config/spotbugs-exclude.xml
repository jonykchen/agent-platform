<?xml version="1.0" encoding="UTF-8"?>
<FindBugsFilter>
  <!-- 排除 Lombok 生成代码 -->
  <Match>
    <Package name="~.*\.model"/>
    <Bug code="EI,EI2,UR,UMAC"/>
  </Match>
  <!-- 排除生成代码 -->
  <Match>
    <Package name="~.*\.gen\..*"/>
  </Match>
  <Match>
    <Package name="~.*generated-sources.*"/>
  </Match>
  <!-- Spring 注入类 -->
  <Match>
    <Bug pattern="URF_UNREAD_PUBLIC_OR_PROTECTED_FIELD"/>
    <Class name="~.*Config$|.*Configuration$|.*Properties$"/>
  </Match>
</FindBugsFilter>
